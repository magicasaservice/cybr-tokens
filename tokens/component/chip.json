{
  "component": {
    "chip": {
      "fontFamily": {
        "default": {
          "$value": "{app.fontFamily.component.text}",
          "$type": "fontFamily"
        },
        "symbol": {
          "$value": "{app.fontFamily.component.symbol}",
          "$type": "fontFamily"
        }
      },
      "fontWeight": {
        "default": {
          "$value": "{app.fontWeight.component.text.strong}",
          "$type": "fontWeight"
        },
        "symbol": {
          "$value": "{app.fontWeight.component.symbol.default}",
          "$type": "fontWeight"
        },
        "icon": {
          "$value": "{app.fontWeight.component.symbol.alt}",
          "$type": "fontWeight"
        }
      },
      "lineHeight": {
        "default": {
          "$value": "{app.lineHeight.default}",
          "$type": "lineHeight"
        },
        "symbol": {
          "$value": "{app.lineHeight.none}",
          "$type": "lineHeight"
        }
      },
      "fontSize": {
        "default": {
          "sm": {
            "$value": "{app.fontSize.component.text.xs}",
            "$type": "fontSizes"
          },
          "md": {
            "$value": "{app.fontSize.component.text.sm}",
            "$type": "fontSizes"
          },
          "lg": {
            "$value": "{app.fontSize.component.text.md}",
            "$type": "fontSizes"
          }
        },
        "symbol": {
          "sm": {
            "$value": "{component.chip.fontSize.symbol.md} - 0.125rem",
            "$type": "fontSizes"
          },
          "md": {
            "$value": "{app.fontSize.component.symbol.lg}",
            "$type": "fontSizes"
          },
          "lg": {
            "$value": "{component.chip.fontSize.symbol.md} + 0.125rem",
            "$type": "fontSizes"
          }
        }
      },
      "icon": {
        "sm": {
          "$value": "{component.chip.fontSize.symbol.sm} + 0.25rem",
          "$type": "fontSizes"
        },
        "md": {
          "$value": "{component.chip.fontSize.symbol.md} + 0.25rem",
          "$type": "fontSizes"
        },
        "lg": {
          "$value": "{component.chip.fontSize.symbol.lg} + 0.25rem",
          "$type": "fontSizes"
        }
      },
      "letterSpacing": {
        "default": {
          "$value": "{app.letterSpacing.component.default}",
          "$type": "letterSpacing"
        }
      },
      "textCase": {
        "default": {
          "$value": "{app.textCase.component.default}",
          "$type": "textCase"
        }
      },
      "color": {
        "default": {
          "solid": {
            "bg": {
              "default": {
                "$value": "{app.color.component.primary.bg.solid.default}",
                "$type": "color"
              },
              "hover": {
                "$value": "{app.color.component.primary.bg.solid.hover}",
                "$type": "color"
              },
              "active": {
                "$value": "{app.color.component.primary.bg.solid.active}",
                "$type": "color"
              },
              "dragged": {
                "$value": "{app.color.component.primary.bg.solid.active}",
                "$type": "color"
              }
            },
            "fg": {
              "default": {
                "$value": "{app.color.component.primary.fg.onSolid.default}",
                "$type": "color"
              }
            }
          },
          "subtle": {
            "bg": {
              "default": {
                "$value": "{app.color.component.primary.bg.subtle.default}",
                "$type": "color"
              },
              "hover": {
                "$value": "{app.color.component.primary.bg.subtle.hover}",
                "$type": "color"
              },
              "active": {
                "$value": "{app.color.component.primary.bg.subtle.active}",
                "$type": "color"
              },
              "dragged": {
                "$value": "{app.color.component.primary.bg.subtle.active}",
                "$type": "color"
              }
            },
            "fg": {
              "default": {
                "$value": "{app.color.component.primary.fg.onSubtle.default}",
                "$type": "color"
              }
            }
          },
          "outline": {
            "bg": {
              "dragged": {
                "$value": "transparent",
                "$type": "color"
              }
            },
            "border": {
              "default": {
                "$value": "{app.color.component.primary.border.subtle.default}",
                "$type": "color"
              },
              "hover": {
                "$value": "{app.color.component.primary.border.subtle.hover}",
                "$type": "color"
              },
              "active": {
                "$value": "{app.color.component.primary.border.subtle.active}",
                "$type": "color"
              },
              "dragged": {
                "$value": "{app.color.component.primary.border.subtle.active}",
                "$type": "color"
              }
            },
            "fg": {
              "default": {
                "$value": "{app.color.component.primary.fg.solid.default}",
                "$type": "color"
              }
            }
          }
        },
        "disabled": {
          "solid": {
            "bg": {
              "default": {
                "$value": "{app.color.component.disabled.bg.solid.default}",
                "$type": "color"
              }
            },
            "fg": {
              "default": {
                "$value": "{app.color.component.disabled.fg.solid.default}",
                "$type": "color"
              }
            }
          },
          "subtle": {
            "bg": {
              "default": {
                "$value": "{app.color.component.disabled.bg.subtle.default}",
                "$type": "color"
              }
            },
            "fg": {
              "default": {
                "$value": "{app.color.component.disabled.fg.solid.default}",
                "$type": "color"
              }
            }
          },
          "outline": {
            "border": {
              "default": {
                "$value": "{app.color.component.disabled.border.subtle.default}",
                "$type": "color"
              }
            },
            "fg": {
              "default": {
                "$value": "{app.color.component.disabled.fg.solid.default}",
                "$type": "color"
              }
            }
          }
        },
        "focus": {
          "border": {
            "default": {
              "$value": "{app.color.component.focus.border.default}",
              "$type": "color"
            }
          },
          "outline": {
            "default": {
              "$value": "{app.color.component.focus.outline.default}",
              "$type": "color"
            }
          }
        }
      },
      "dimension": {
        "height": {
          "sm": {
            "$value": "1.5rem",
            "$type": "dimension"
          },
          "md": {
            "$value": "2rem",
            "$type": "dimension"
          },
          "lg": {
            "$value": "2.5rem",
            "$type": "dimension"
          }
        },
        "padding": {
          "sm": {
            "$value": "0.3125rem",
            "$type": "dimension"
          },
          "md": {
            "$value": "0.5rem",
            "$type": "dimension"
          },
          "lg": {
            "$value": "0.75rem",
            "$type": "dimension"
          },
          "label": {
            "$value": "4px",
            "$type": "dimension"
          }
        },
        "gap": {
          "sm": {
            "$value": "0.0625rem",
            "$type": "dimension"
          },
          "md": {
            "$value": "0.125rem",
            "$type": "dimension"
          },
          "lg": {
            "$value": "0.25rem",
            "$type": "dimension"
          }
        },
        "radius": {
          "default": {
            "sm": {
              "$value": "{app.dimension.component.radius.default.xs}",
              "$type": "dimension"
            },
            "md": {
              "$value": "{app.dimension.component.radius.default.sm}",
              "$type": "dimension"
            },
            "lg": {
              "$value": "{app.dimension.component.radius.default.md}",
              "$type": "dimension"
            }
          },
          "inline": {
            "sm": {
              "$value": "{component.chip.dimension.radius.default.sm} - {component.chip.dimension.radius.default.md} - {component.chip.dimension.radius.default.sm}",
              "$type": "dimension"
            },
            "md": {
              "$value": "{component.chip.dimension.radius.default.md} - {component.chip.dimension.radius.default.md} - {component.chip.dimension.radius.default.sm}",
              "$type": "dimension"
            },
            "lg": {
              "$value": "{component.chip.dimension.radius.default.lg} - {component.chip.dimension.radius.default.md} - {component.chip.dimension.radius.default.sm}",
              "$type": "dimension"
            }
          }
        },
        "border": {
          "default": {
            "$value": "{app.dimension.label.border.default}",
            "$type": "dimension"
          }
        },
        "outline": {
          "focus": {
            "$value": "{app.dimension.component.outline.focus.default}"
          }
        },
        "symbol": {
          "sm": {
            "default": {
              "$value": "{component.chip.fontSize.symbol.sm}",
              "$type": "dimension"
            },
            "icon": {
              "$value": "{component.chip.dimension.symbol.sm.default} + {component.chip.config.symbol.icon.step}",
              "$type": "dimension"
            }
          },
          "md": {
            "default": {
              "$value": "{component.chip.fontSize.symbol.md}",
              "$type": "dimension"
            },
            "icon": {
              "$value": "{component.chip.dimension.symbol.md.default} + {component.chip.config.symbol.icon.step}",
              "$type": "dimension"
            }
          },
          "lg": {
            "default": {
              "$value": "{component.chip.fontSize.symbol.lg}",
              "$type": "dimension"
            },
            "icon": {
              "$value": "{component.chip.dimension.symbol.lg.default} + {component.chip.config.symbol.icon.step}",
              "$type": "dimension"
            }
          }
        },
        "blur": {
          "default": {
            "$value": "4rem",
            "$type": "dimension"
          }
        }
      },
      "boxShadow": {
        "dragged": {
          "$value": [
            {
              "x": "0",
              "y": "0.375rem",
              "blur": "1rem",
              "spread": "0",
              "color": "{app.color.surface.shadow.strong}",
              "type": "dropShadow"
            }
          ],
          "$type": "boxShadow"
        }
      }
    }
  }
}
