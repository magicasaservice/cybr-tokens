{
  "app": {
    "dimension": {
      "component": {
        "radius": {
          "round": {
            "$value": "9999px",
            "$type": "dimension"
          },
          "compact": {
            "xs": {
              "$value": "{config.dimension.radius.base} * 1.75",
              "$type": "dimension"
            },
            "sm": {
              "$value": "{config.dimension.radius.base} * 2.25",
              "$type": "dimension"
            },
            "md": {
              "$value": "{config.dimension.radius.base} * 2.75",
              "$type": "dimension"
            },
            "lg": {
              "$value": "{config.dimension.radius.base} * 3.25",
              "$type": "dimension"
            },
            "xl": {
              "$value": "{config.dimension.radius.base} * 3.75",
              "$type": "dimension"
            }
          },
          "default": {
            "2xs": {
              "$value": "{config.dimension.radius.base} * 4.25",
              "$type": "dimension"
            },
            "xs": {
              "$value": "{config.dimension.radius.base} * 4.75",
              "$type": "dimension"
            },
            "sm": {
              "$value": "{config.dimension.radius.base} * 5.25",
              "$type": "dimension"
            },
            "md": {
              "$value": "{config.dimension.radius.base} * 5.75",
              "$type": "dimension"
            },
            "lg": {
              "$value": "{config.dimension.radius.base} * 6.25",
              "$type": "dimension"
            },
            "xl": {
              "$value": "{config.dimension.radius.base} * 6.75",
              "$type": "dimension"
            },
            "2xl": {
              "$value": "{config.dimension.radius.base} * 7.25",
              "$type": "dimension"
            }
          }
        }
      }
    }
  }
}
